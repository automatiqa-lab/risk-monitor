# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── LLM provider ─────────────────────────────────────────────────────────────
# Pick whichever provider matches `llm.model` in config/settings.yaml and set
# its key. You only need the one you actually use.
#
# Anthropic (default - model: claude-sonnet-4-6)
ANTHROPIC_API_KEY=sk-ant-...
# OpenAI (model: gpt-4o-mini, etc.)
# OPENAI_API_KEY=sk-...
# Local / self-hosted endpoint (e.g. Ollama). Point LiteLLM at it:
# LLM_API_BASE=http://localhost:11434

# ── Optional - Email delivery ────────────────────────────────────────────────
# SMTP credentials OR SendGrid API key
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@example.com
# SMTP_PASSWORD=your-app-password
# SENDGRID_API_KEY=SG...

# ── Optional - NewsAPI (broader news coverage) ───────────────────────────────
# NEWS_API_KEY=...

# ── Optional - Override settings.yaml values ─────────────────────────────────
# OUTPUT_DIR=./output
# LOOKBACK_DAYS=7
